  "item": [
    {
      "name": "Get Valid Pokemon",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Pokémon Found\", function () {",
              "    const data = pm.response.json();",
              "    pm.expect(data.name).to.eql(\"pikachu\"); // checks the actual content of the response, not just 200s, verifying CF Worker returned the right pokemon ",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "}); // Content-Type check confrims header I set in Worker code (Content-Type: application/json) is actually showing up, extra check tying my test back to a sepcific line of code"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi-worker.edwinhchun.workers.dev/pokemon/pikachu",
          "protocol": "https",
          "host": [
            "pokeapi-worker",
            "edwinhchun",
            "workers",
            "dev"
          ],
          "path": [
            "pokemon",
            "pikachu"
          ]
        }
      },
      "response": []
    },
